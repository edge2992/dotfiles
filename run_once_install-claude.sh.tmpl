#!/usr/bin/env bash
{{ includeTemplate "install-prelude.sh" }}

# Ensure ~/.local/bin is in PATH for this script
export PATH="$HOME/.local/bin:$PATH"

# Claude Code CLI (Native Install)
if command -v claude >/dev/null 2>&1; then
  log "Claude CLI is already installed: $(claude --version 2>/dev/null || echo 'unknown version')"
else
  log "Installing Claude CLI (native)..."
  curl -fsSL https://claude.ai/install.sh | bash
fi
