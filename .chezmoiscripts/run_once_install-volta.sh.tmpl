#!/usr/bin/env bash
set -euo pipefail
{{ includeTemplate "install-prelude.sh" }}

# Volta (Node.js manager)
if command -v volta >/dev/null 2>&1; then
  log "Volta is already installed"
else
  log "Installing Volta..."
  curl https://get.volta.sh | bash
fi

export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"

# Node.js and global packages
log "Ensuring Node.js and global packages..."
volta install node
volta install yarn
volta install aicommits
volta install ccusage
volta install repomix
