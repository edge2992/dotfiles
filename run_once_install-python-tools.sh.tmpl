#!/usr/bin/env bash
set -euo pipefail

log() { echo "[install] $*"; }

if [ -n "${CI:-}" ]; then
  log "CI environment detected. Skipping Python tools installation."
  exit 0
fi

{{ if eq .chezmoi.os "linux" }}
# Install pynvim for Neovim Python support via apt
if ! python3 -c "import pynvim" 2>/dev/null; then
  log "Installing python3-pynvim for Neovim..."
  sudo apt install -y python3-pynvim
fi
{{ end }}

# uv (Python package manager)
if command -v uv >/dev/null 2>&1; then
  log "uv is already installed: $(uv --version)"
else
  log "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
fi