{
  "cleanupPeriodDays": 60,
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**.md)",
      "Write(**.lua)",
      "Write(**.sh)",
      "Write(**.toml)",
      "Write(**.json)",
      "Write(**.yml)",
      "Write(**.yaml)",
      "Write(**.tmpl)",
      "Write(**.vim)",
      "Write(**.zsh)",
      "Write(**.conf)",
      "Write(dot_**)",
      "Write(private_dot_**)",
      "Write(run_once_**)",
      "Write(run_onchange_**)",
      "Write(.tmp/**)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git merge:*)",
      "Bash(git tag:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(gh:*)",
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi apply:*)",
      "Bash(chezmoi execute-template:*)",
      "Bash(chezmoi data:*)",
      "Bash(chezmoi managed:*)",
      "Bash(chezmoi cat-config:*)",
      "Bash(chezmoi source-path:*)",
      "Bash(chezmoi target-path:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(npm run:*)",
      "Bash(npx:*)",
      "Bash(make:*)",
      "Bash(* --version)",
      "Bash(* --help)",
      "WebFetch(domain:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__serena"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(chezmoi destroy:*)",
      "Bash(chezmoi purge:*)",
      "Read(.env*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env*)"
    ]
  },
  "model": "opus",
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "printf '%s@%s:%s' \"$(whoami)\" \"$(hostname -s)\" \"$(pwd)\" | sed 's|'\"$HOME\"'|~|'"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true,
    "context7@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "preferredNotifChannel": "auto"
}
