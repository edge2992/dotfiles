#!/usr/bin/env bash
set -euo pipefail

VAULT="$HOME/Documents/ob_edgissa"
DIR="$VAULT/memo/_posts"
DATE="$(date +%Y-%m-%d)"
TIME="$(date +%H%M%S)"

title="${*:-memo}"
slug="$(echo "$title" | tr ' ' '-' | tr -cd '[:alnum:]-_ぁ-んァ-ン一-龥')"
file="$DIR/${DATE}-${TIME}-${slug}.md"

cat >"$file" <<EOF
---
created: $(date '+%Y-%m-%d %H:%M')
tags:
  - inbox
---

# $title

EOF

vim "$file"
