#!/usr/bin/env bash
# Claude-powered git commit — delegates to the /auto-commit skill.
# Reads the staged diff file by file, writes a Conventional Commits
# message, and commits automatically (no editor, no confirmation).
# Usage: git-claude-commit [additional context]

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Ensure there is something staged. If nothing is staged but the working
# tree has changes, stage everything (preserves the old convenience).
if ! git diff --cached --quiet 2>/dev/null; then
    :
elif ! git diff --quiet 2>/dev/null; then
    echo -e "${YELLOW}⚡ No staged changes. Staging all changes...${NC}"
    git add -A
else
    echo -e "${RED}✗ No changes to commit${NC}"
    exit 1
fi

# The /auto-commit skill drives the commit, so the Claude CLI is required.
if ! command -v claude &> /dev/null; then
    echo -e "${RED}✗ Claude CLI not found. Install: curl -fsSL https://claude.ai/install.sh | bash${NC}"
    exit 1
fi

# Show what will be committed.
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}📝 Staged changes${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
git diff --cached --stat
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Delegate to /auto-commit. acceptEdits overrides the plan defaultMode so the
# headless run can act without prompts, while --allowedTools restricts it to the
# git commands the skill needs (least privilege, not a full bypass). Haiku keeps
# it fast.
echo -e "${GREEN}🤖 Analyzing diff and committing with Claude...${NC}"

PROMPT="/auto-commit"
if [ "$#" -gt 0 ]; then
    PROMPT="/auto-commit $*"
fi

claude -p "$PROMPT" \
    --model haiku \
    --permission-mode acceptEdits \
    --allowedTools \
        "Bash(git diff:*)" \
        "Bash(git log:*)" \
        "Bash(git status:*)" \
        "Bash(git show:*)" \
        "Bash(git rev-parse:*)" \
        "Bash(git commit:*)"

echo ""
echo -e "${GREEN}✓ Done${NC}"
git log -1 --pretty=format:"  %C(yellow)%h%Creset %s %C(blue)(%cr)%Creset"
echo ""
